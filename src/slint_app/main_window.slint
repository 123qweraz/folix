import { VerticalBox, Button } from "std-widgets.slint";
import { ReflowViewer } from "reflow_viewer.slint";
import { PdfViewer } from "pdf_viewer.slint";

export component MainWindow inherits Window {
    title: "Folix";
    preferred-width: 1024px;
    preferred-height: 768px;

    in-out property <string> status-text: "Ready";

    // Reflow properties
    in property <bool> show-reflow: false;
    in property <string> reflow-content: "";
    in property <string> chapter-title: "";
    in property <int> current-chapter: 0;
    in property <int> total-chapters: 0;

    // PDF properties
    in property <bool> show-pdf: false;
    in property <image> page-image;
    in property <string> page-title: "";
    in property <int> current-page: 0;
    in property <int> total-pages: 0;

    callback open-file();
    callback prev-chapter();
    callback next-chapter();
    callback prev-page();
    callback next-page();
    callback page-clicked(float, float);
    callback copy-selected();

    VerticalBox {
        // Tab bar area
        Rectangle {
            height: 40px;
            background: #e0e0e0;
            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                spacing: 8px;
                Text {
                    text: "Folix";
                    vertical-alignment: center;
                    font-size: 16px;
                    font-weight: 600;
                }
                HorizontalLayout {
                    horizontal-stretch: 1;
                }
                Button {
                    text: "Open";
                    clicked => { root.open-file(); }
                }
            }
        }

        // Content area - Reflow
        if (root.show-reflow) : ReflowViewer {
            content: root.reflow-content;
            chapter-title: root.chapter-title;
            current-chapter: root.current-chapter;
            total-chapters: root.total-chapters;
            prev-chapter => { root.prev-chapter(); }
            next-chapter => { root.next-chapter(); }
            vertical-stretch: 1;
        }

        // Content area - PDF
        if (root.show-pdf) : PdfViewer {
            page-image: root.page-image;
            page-title: root.page-title;
            current-page: root.current-page;
            total-pages: root.total-pages;
            prev-page => { root.prev-page(); }
            next-page => { root.next-page(); }
            page-clicked(x, y) => { root.page-clicked(x, y); }
            copy-selected => { root.copy-selected(); }
            vertical-stretch: 1;
        }

        // Content area - Home
        if (!root.show-reflow && !root.show-pdf) : Rectangle {
            background: white;
            vertical-stretch: 1;
            Text {
                text: "Welcome to Folix\nOpen a file to get started";
                wrap: word-wrap;
                horizontal-alignment: center;
                vertical-alignment: center;
                font-size: 18px;
                color: #888;
            }
        }

        // Status bar
        Rectangle {
            height: 28px;
            background: #f0f0f0;
            Text {
                text <=> root.status-text;
                x: 8px;
                vertical-alignment: center;
                font-size: 12px;
                color: #666;
            }
        }
    }
}
