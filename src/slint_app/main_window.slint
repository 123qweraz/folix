import { VerticalBox, Button } from "std-widgets.slint";
import { ReflowViewer } from "reflow_viewer.slint";
import { PdfViewer } from "pdf_viewer.slint";

export struct TabInfo {
    title: string,
    is-active: bool,
}

export component MainWindow inherits Window {
    title: "Folix";
    preferred-width: 1024px;
    preferred-height: 768px;

    in-out property <string> status-text: "Ready";
    in property <[TabInfo]> tabs;

    // Reflow properties
    in property <bool> show-reflow: false;
    in property <string> reflow-content: "";
    in property <string> chapter-title: "";
    in property <int> current-chapter: 0;
    in property <int> total-chapters: 0;

    // PDF properties
    in property <bool> show-pdf: false;
    in property <image> page-image;
    in property <string> page-title: "";
    in property <int> current-page: 0;
    in property <int> total-pages: 0;

    callback open-file();
    callback close-tab(int);
    callback switch-tab(int);
    callback prev-chapter();
    callback next-chapter();
    callback prev-page();
    callback next-page();
    callback page-clicked(float, float);
    callback copy-selected();

    FocusScope {
        width: 0px;
        height: 0px;
        KeyBinding {
            keys: @keys(Control + O);
            activated => { root.open-file(); }
        }
        KeyBinding {
            keys: @keys(Control + W);
            activated => { root.close-tab(-1); }
        }
    }

    VerticalBox {
        // Tab bar
        Rectangle {
            height: 36px;
            background: #e0e0e0;
            HorizontalLayout {
                padding-left: 4px;
                spacing: 2px;
                HorizontalLayout {
                    horizontal-stretch: 1;
                    for tab[idx] in root.tabs: Rectangle {
                        min-width: 80px;
                        max-width: 160px;
                        height: 100%;
                        background: tab.is-active ? #fff : transparent;
                        border-radius: 4px;
                        TouchArea {
                            clicked => { root.switch-tab(idx); }
                            HorizontalLayout {
                                padding-left: 10px;
                                padding-right: 4px;
                                spacing: 4px;
                                Text {
                                    text: tab.title;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                    font-size: 12px;
                                    overflow: elide;
                                }
                                Rectangle {
                                    width: 18px;
                                    height: 18px;
                                    TouchArea {
                                        clicked => { root.close-tab(idx); }
                                        Rectangle {
                                            width: 100%;
                                            height: 100%;
                                            border-radius: 2px;
                                            Text {
                                                text: "×";
                                                font-size: 12px;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                                color: #666;
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
                Button {
                    text: "+";
                    min-width: 28px;
                    min-height: 28px;
                    clicked => { root.open-file(); }
                }
            }
        }

        // Content - Reflow
        if (root.show-reflow) : ReflowViewer {
            content: root.reflow-content;
            chapter-title: root.chapter-title;
            current-chapter: root.current-chapter;
            total-chapters: root.total-chapters;
            prev-chapter => { root.prev-chapter(); }
            next-chapter => { root.next-chapter(); }
            vertical-stretch: 1;
        }

        // Content - PDF
        if (root.show-pdf) : PdfViewer {
            page-image: root.page-image;
            page-title: root.page-title;
            current-page: root.current-page;
            total-pages: root.total-pages;
            prev-page => { root.prev-page(); }
            next-page => { root.next-page(); }
            page-clicked(x, y) => { root.page-clicked(x, y); }
            copy-selected => { root.copy-selected(); }
            vertical-stretch: 1;
        }

        // Content - Home
        if (!root.show-reflow && !root.show-pdf) : Rectangle {
            background: white;
            vertical-stretch: 1;
            Text {
                text: "Welcome to Folix\nOpen a file to get started";
                wrap: word-wrap;
                horizontal-alignment: center;
                vertical-alignment: center;
                font-size: 18px;
                color: #888;
            }
        }

        // Status bar
        Rectangle {
            height: 28px;
            background: #f0f0f0;
            Text {
                text <=> root.status-text;
                x: 8px;
                vertical-alignment: center;
                font-size: 12px;
                color: #666;
            }
        }
    }
}
