import { VerticalBox, Button, ScrollView } from "std-widgets.slint";

export component PdfViewer {
    in property <image> page-image;
    in property <string> page-title;
    in property <int> current-page;
    in property <int> total-pages;

    callback prev-page();
    callback next-page();
    callback page-clicked(float, float);
    callback copy-selected();

    VerticalBox {
        Rectangle {
            height: 36px;
            background: #f5f5f5;
            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;
                spacing: 8px;
                Text {
                    text: root.page-title;
                    vertical-alignment: center;
                    font-size: 14px;
                    horizontal-stretch: 1;
                }
                Text {
                    text: (root.current-page + 1) + " / " + root.total-pages;
                    vertical-alignment: center;
                    font-size: 12px;
                    color: #888;
                }
                Button {
                    text: "Copy";
                    clicked => { root.copy-selected(); }
                }
                Button {
                    text: "Prev";
                    enabled: root.current-page > 0;
                    clicked => { root.prev-page(); }
                }
                Button {
                    text: "Next";
                    enabled: root.current-page + 1 < root.total-pages;
                    clicked => { root.next-page(); }
                }
            }
        }

        ScrollView {
            vertical-stretch: 1;
            TouchArea {
                Image {
                    source: root.page-image;
                }
                clicked => {
                    root.page-clicked(self.pressed-x / 1px, self.pressed-y / 1px);
                }
            }
        }
    }
}
